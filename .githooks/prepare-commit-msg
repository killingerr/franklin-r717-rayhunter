#!/bin/sh
# Strip Cursor agent attribution from commit messages (local IDE hook).
# Enable: git config core.hooksPath .githooks
test -n "$1" && test -f "$1" || exit 0
sed -i.bak \
	-e '/[Cc]o-[Aa]uthored-[Bb]y:.*[Cc]ursor/d' \
	-e '/cursoragent@cursor\.com/d' \
	-e '/[Mm]ade-with:.*[Cc]ursor/d' \
	"$1"
rm -f "$1.bak"
